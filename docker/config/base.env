# Shared environment defaults for all stacks (checked in, safe defaults only).
# Copy to docker/config/base.env.local for per-operator overrides if needed.

LOCAL_ADDONS_DIRS=
ODOO_WITHOUT_DEMO=true
ODOO_HTTP_INTERFACE=0.0.0.0
ODOO_PROXY_MODE=True
ODOO_LIST_DB=False
ODOO_BASE_RUNTIME_IMAGE=ghcr.io/cbusillo/odoo-enterprise-docker:19.0-runtime
ODOO_BASE_DEVTOOLS_IMAGE=ghcr.io/cbusillo/odoo-enterprise-docker:19.0-devtools
ENV_OVERRIDE_AUTHENTIK__DISABLE_PROVIDERS=Odoo.com
ENV_OVERRIDE_DISABLE_CRON=true

# Odoo runtime baseline (derived from upstream OPW production, scaled for shared local hosts)
ODOO_DB_MAXCONN=44
ODOO_MAX_CRON_THREADS=2
ODOO_WORKERS=6
ODOO_LIMIT_TIME_CPU=600
ODOO_LIMIT_TIME_REAL=1800
ODOO_LIMIT_TIME_REAL_CRON=1800
ODOO_LIMIT_MEMORY_SOFT=671088640
ODOO_LIMIT_MEMORY_HARD=805306368

# PostgreSQL baseline (derived from upstream OPW production, scaled for shared local hosts)
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=1GB
POSTGRES_EFFECTIVE_CACHE_SIZE=4GB
POSTGRES_WORK_MEM=32MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_MAX_WAL_SIZE=1GB
POSTGRES_MIN_WAL_SIZE=80MB
POSTGRES_CHECKPOINT_TIMEOUT=5min
POSTGRES_RANDOM_PAGE_COST=4
POSTGRES_EFFECTIVE_IO_CONCURRENCY=1
