schema_version = 1

# Secret layering order (later wins):
# 1) [shared]
# 2) [contexts.<context>.shared]
# 3) [contexts.<context>.instances.<instance>.env]
#
# Keep real values in `platform/secrets.toml` (gitignored).

[shared]
ODOO_MASTER_PASSWORD = "change_me"
ODOO_DB_USER = "odoo"
ODOO_DB_PASSWORD = "change_me"
GITHUB_TOKEN = ""

[contexts.cm.shared]
ENV_OVERRIDE_DISABLE_CRON = true
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL_FREEZE = true
ENV_OVERRIDE_SHOPIFY__TEST_STORE = true
ENV_OVERRIDE_SHOPIFY__API_VERSION = "2026-01"
ENV_OVERRIDE_SHOPIFY__PRODUCTION_INDICATORS = "production,live,prod-"
ENV_OVERRIDE_SHOPIFY__ALLOW_PRODUCTION = false

[contexts.cm.instances.local.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://cm-local.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "cm-local"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.cm.instances.dev.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://cm-dev.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "cm-dev"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.cm.instances.testing.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://cm-testing.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "cm-testing"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.cm.instances.prod.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://cm-prod.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "cm-prod"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.opw.shared]
ENV_OVERRIDE_DISABLE_CRON = true
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL_FREEZE = true
ENV_OVERRIDE_SHOPIFY__TEST_STORE = true
ENV_OVERRIDE_SHOPIFY__API_VERSION = "2026-01"
ENV_OVERRIDE_SHOPIFY__PRODUCTION_INDICATORS = "yps-your-part-supplier,outboardpartswarehouse,opw-prod,production,live"
ENV_OVERRIDE_SHOPIFY__ALLOW_PRODUCTION = false

[contexts.opw.instances.local.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://opw-local.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "opw-local"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.opw.instances.dev.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://opw-dev.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "opw-dev"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.opw.instances.testing.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://opw-testing.example.com"
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "opw-testing"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""

[contexts.opw.instances.prod.env]
ENV_OVERRIDE_CONFIG_PARAM__WEB__BASE__URL = "https://opw-prod.example.com"
ENV_OVERRIDE_SHOPIFY__TEST_STORE = false
ENV_OVERRIDE_SHOPIFY__SHOP_URL_KEY = "opw-prod"
ENV_OVERRIDE_SHOPIFY__API_TOKEN = ""
ENV_OVERRIDE_SHOPIFY__WEBHOOK_KEY = ""
