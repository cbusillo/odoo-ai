# Core Odoo runtime
ODOO_MASTER_PASSWORD=replace-me
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=replace-me

# Optional deploy integration
DOKPLOY_HOST=
DOKPLOY_TOKEN=

# Optional ship mode: auto (default), compose, application
# DOKPLOY_SHIP_MODE=auto
# DOKPLOY_SHIP_MODE_CM_DEV=compose

# Optional Dokploy app name overrides (defaults: <context>-<instance>)
# DOKPLOY_APP_NAME_CM_DEV=cm-dev
# DOKPLOY_APP_NAME_CM_TESTING=cm-testing
# DOKPLOY_APP_NAME_CM_PROD=cm-prod
# DOKPLOY_APP_NAME_OPW_DEV=opw-dev
# DOKPLOY_APP_NAME_OPW_TESTING=opw-testing
# DOKPLOY_APP_NAME_OPW_PROD=opw-prod

# Optional Dokploy compose name/id overrides (defaults: <context>-<instance>)
# DOKPLOY_COMPOSE_NAME_CM_DEV=cm-dev
# DOKPLOY_COMPOSE_ID_CM_DEV=

# Optional CM Shopify keys (examples only)
CM_LOCAL_SHOPIFY_ADMIN_API_KEY=
CM_LOCAL_SHOPIFY_ADMIN_API_SECRET=
CM_LOCAL_SHOPIFY_WEBHOOK_SECRET=
